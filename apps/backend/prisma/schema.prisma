generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
}

// ─── EMPRESAS ────────────────────────────────────────────────────────────────

model Company {
  id                    String        @id @default(cuid())
  name                  String
  slug                  String        @unique
  whatsappPhoneNumberId String?
  whatsappToken         String?
  aiProvider            String        @default("openai")
  aiModel               String        @default("gpt-4o-mini")
  tokenLimit            Int           @default(1000000)
  tokensUsed            Int           @default(0)
  userLimit             Int           @default(10)
  isActive              Boolean       @default(true)
  plan                  String        @default("trial")
  logoUrl               String?
  primaryColor          String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  users              User[]
  agents             Agent[]
  products           Product[]
  leads              Lead[]
  conversations      Conversation[]
  messages           Message[]
  quotes             Quote[]
  commercialRules    CommercialRule?
  tokenUsageLogs     TokenUsageLog[]
  companyProducts    CompanyProduct[]
  productSuggestions ProductSuggestion[]
  orchestrationLogs  OrchestrationLog[]

  @@map("companies")
}

// ─── USUÁRIOS ────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  companyId    String?
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("operator")
  isActive     Boolean   @default(true)
  tokensUsed   Int       @default(0)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company       Company?  @relation(fields: [companyId], references: [id])
  assignedLeads Lead[]    @relation("AssignedLeads")
  messages      Message[] @relation("SentMessages")

  @@map("users")
}

// ─── AGENTES ─────────────────────────────────────────────────────────────────
// isTemplate=true + companyId=null  → template global (gerenciado pelo super admin)
// isTemplate=false + companyId=set  → agente ativo de uma empresa (instância do template)

model Agent {
  id              String   @id @default(cuid())
  companyId       String?                         // null = template global
  templateId      String?                         // ID do template de origem (se for instância)
  isTemplate      Boolean  @default(false)
  name            String
  description     String?
  type            String   @default("commercial")
  scope           String   @default("external")
  prompt          String
  promptVersion   Int      @default(1)
  aiProvider      String?                         // null = use company default
  aiModel         String?                         // null = use company default
  isActive        Boolean  @default(true)
  triggerKeywords String[] @default([])
  requiredFields  String[] @default([])
  followUpRules   Json     @default("[]")
  // Campos dinâmicos que a empresa precisa preencher ao ativar o template
  // Ex: [{ key: "company_name", label: "Nome da Empresa", type: "text", required: true }]
  dynamicFields   Json     @default("[]")
  // Valores dinâmicos preenchidos pela empresa (apenas em instâncias, não em templates)
  dynamicValues   Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company        Company?             @relation(fields: [companyId], references: [id])
  template       Agent?               @relation("TemplateInstances", fields: [templateId], references: [id])
  instances      Agent[]              @relation("TemplateInstances")
  conversations  Conversation[]
  messages       Message[]
  promptVersions AgentPromptVersion[]

  @@map("agents")
}

model AgentPromptVersion {
  id        String   @id @default(cuid())
  agentId   String
  version   Int
  prompt    String
  label     String?
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, version])
  @@map("agent_prompt_versions")
}

// ─── PRODUTOS / CATÁLOGO GLOBAL ──────────────────────────────────────────────
// isGlobal=true + companyId=null  → catálogo global (gerenciado pelo super admin)
// isGlobal=false + companyId=set → produto exclusivo da empresa (legado / aprovados)

model Product {
  id                   String   @id @default(cuid())
  companyId            String?                     // null = produto global
  isGlobal             Boolean  @default(false)
  name                 String
  category             String
  description          String?
  dailyPrice           Decimal  @db.Decimal(10, 2)
  weeklyPrice          Decimal? @db.Decimal(10, 2)
  monthlyPrice         Decimal? @db.Decimal(10, 2)
  minimumDays          Int      @default(1)
  freightCalculation   String   @default("by_equipment")
  requiredInfoForQuote String[] @default([])
  commonQuestions      String[] @default([])
  isMostSold           Boolean  @default(false)
  isHighRevenue        Boolean  @default(false)
  isActive             Boolean  @default(true)
  imageUrl             String?
  documents            Json     @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company         Company?         @relation(fields: [companyId], references: [id])
  quoteItems      QuoteItem[]
  companyProducts CompanyProduct[]

  @@map("products")
}

// Seleção de produtos globais por empresa — inclui preços próprios da empresa
model CompanyProduct {
  id           String   @id @default(cuid())
  companyId    String
  productId    String
  isActive     Boolean  @default(true)
  // Preços praticados pela empresa (sobrescrevem os preços de referência do catálogo global)
  dailyPrice   Decimal? @db.Decimal(10, 2)
  weeklyPrice  Decimal? @db.Decimal(10, 2)
  monthlyPrice Decimal? @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([companyId, productId])
  @@map("company_products")
}

// Sugestão de produto enviada por empresa para aprovação do admin master
model ProductSuggestion {
  id                String   @id @default(cuid())
  companyId         String
  name              String
  category          String
  description       String?
  dailyPrice        Decimal  @db.Decimal(10, 2)
  weeklyPrice       Decimal? @db.Decimal(10, 2)
  monthlyPrice      Decimal? @db.Decimal(10, 2)
  status            String   @default("pending") // pending | approved | rejected
  reviewNote        String?
  approvedProductId String?  // ID do Product global criado após aprovação
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@map("product_suggestions")
}

model CommercialRule {
  id                 String   @id @default(cuid())
  companyId          String   @unique
  hasFixedPriceTable Boolean  @default(true)
  allowsDiscount     Boolean  @default(false)
  maxDiscountPercent Decimal  @default(0) @db.Decimal(5, 2)
  paymentMethods     String[] @default([])
  freightRules       String?
  additionalRules    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@map("commercial_rules")
}

// ─── LEADS ───────────────────────────────────────────────────────────────────

model Lead {
  id                String   @id @default(cuid())
  companyId         String
  name              String?
  companyName       String?
  phone             String
  source            String   @default("whatsapp")
  stage             String   @default("new")
  temperature       String   @default("warm")
  notes             String?
  currentAgentId    String?
  assignedUserId    String?
  context           Json     @default("{}")
  lastInteractionAt DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  assignedUser  User?          @relation("AssignedLeads", fields: [assignedUserId], references: [id])
  conversations Conversation[]
  quotes        Quote[]

  @@unique([companyId, phone])
  @@map("leads")
}

// ─── CONVERSAS ───────────────────────────────────────────────────────────────

model Conversation {
  id               String   @id @default(cuid())
  companyId        String
  leadId           String
  currentAgentId   String?
  stage            String   @default("new")
  context          Json     @default("{}")
  isActive         Boolean  @default(true)
  handedOffToHuman Boolean  @default(false)
  totalTokensUsed  Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company      Company   @relation(fields: [companyId], references: [id])
  lead         Lead      @relation(fields: [leadId], references: [id])
  currentAgent Agent?    @relation(fields: [currentAgentId], references: [id])
  messages     Message[]

  @@map("conversations")
}

model Message {
  id                String   @id @default(cuid())
  companyId         String
  leadId            String
  conversationId    String
  direction         String
  content           String
  role              String   @default("user")
  type              String   @default("text")
  agentId           String?
  sentByUserId      String?
  whatsappMessageId String?
  status            String   @default("pending")
  tokensUsed        Int?
  createdAt         DateTime @default(now())

  company      Company      @relation(fields: [companyId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])
  agent        Agent?       @relation(fields: [agentId], references: [id])
  sentByUser   User?        @relation("SentMessages", fields: [sentByUserId], references: [id])

  @@map("messages")
}

// ─── ORÇAMENTOS ──────────────────────────────────────────────────────────────

model Quote {
  id               String    @id @default(cuid())
  companyId        String
  leadId           String
  totalValue       Decimal   @db.Decimal(10, 2)
  discountPercent  Decimal   @default(0) @db.Decimal(5, 2)
  deliveryLocation String?
  startDate        DateTime?
  endDate          DateTime?
  validUntil       DateTime?
  status           String    @default("draft")
  pdfUrl           String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company Company     @relation(fields: [companyId], references: [id])
  lead    Lead        @relation(fields: [leadId], references: [id])
  items   QuoteItem[]

  @@map("quotes")
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  productId   String
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)
  periodDays  Int

  quote   Quote   @relation(fields: [quoteId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("quote_items")
}

// ─── CONTROLE DE TOKENS ──────────────────────────────────────────────────────

model TokenUsageLog {
  id             String   @id @default(cuid())
  companyId      String
  userId         String?
  agentId        String?
  conversationId String?
  tokensIn       Int
  tokensOut      Int
  totalTokens    Int
  model          String
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@map("token_usage_logs")
}

// ─── LOGS DE ORQUESTRAÇÃO ────────────────────────────────────────────────────

model OrchestrationLog {
  id             String   @id @default(cuid())
  companyId      String
  conversationId String
  leadPhone      String
  step           String   // "client_message" | "router" | "specialist" | "orchestrator" | "send" | "error"
  actor          String
  message        String
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([conversationId, createdAt])
  @@index([companyId, createdAt])
  @@map("orchestration_logs")
}
