# App
NODE_ENV=development
PORT=3001
API_SECRET=your-api-secret-here
JWT_SECRET=your-jwt-secret-here

# Database (Supabase)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI
OPENAI_API_KEY=sk-...

# 360dialog WhatsApp
# sandbox: https://waba-sandbox.360dialog.io | production: https://waba.360dialog.io
DIALOG_360_BASE_URL=https://waba-sandbox.360dialog.io
# URL pública do backend para registrar webhook na 360dialog (ngrok em dev, domínio em prod)
BACKEND_PUBLIC_URL=https://seu-backend.com

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000
